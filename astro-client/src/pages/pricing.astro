---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/sections/Footer.astro";
import BookingModal from "../components/modals/BookingModal.astro";
import InvestmentBuilder from "../components/pricing/InvestmentBuilder";
---

<BaseLayout title="Investment Builder | P. James" description="A La Carte implementation menu across Visual Systems, Digital Engineering, and Autonomous Systems. Build your estimated investment in real time.">
  <Navbar alwaysVisible={true} homeSectionLinks={true} />
  
  <main class="min-h-screen pt-24 md:pt-28 pb-16">
    <section class="container-fluid mb-14">
      <div class="rounded-[var(--radius-xl)] border border-[rgb(var(--border)/0.12)] bg-[rgb(var(--panel)/0.62)] backdrop-blur-md p-7 md:p-10">
        <h1 class="text-2xl text-[var(--step-4)] leading-[0.95] text-text max-w-4xl mb-4">
          Interactive Investment Builder for Precision-Led Implementation
        </h1>
        <p class="text-[var(--step-0)] text-muted max-w-3xl leading-relaxed">
          Select modules across Visual Systems, Digital Engineering, and Autonomous Systems.
          Build your deployment scope line by line and review a live total estimated investment before execution.
        </p>
      </div>
    </section>

    <section class="container-fluid mb-24">
      <InvestmentBuilder client:load />
    </section>

    <section class="container-fluid max-w-4xl mx-auto text-center">
      <div class="rounded-[var(--radius-xl)] border border-[rgb(var(--border)/0.12)] bg-[rgb(var(--panel)/0.68)] p-8">
        <h2 class="text-2xl font-bold text-[var(--step-2)] text-text mb-3">
         Need Something Custom?
        </h2>
        <p class="text-muted mb-6">
          Every business is unique. Let's discuss your specific requirements.
        </p>
        <button class="action-book inline-flex items-center gap-2 px-7 py-3 rounded-full bg-[rgb(var(--accent))] text-[rgb(var(--bg))] font-semibold hover:brightness-110 transition">
          Let's talk 
        </button>
      </div>
    </section>
  </main>
  
  <Footer />
  <BookingModal />
</BaseLayout>
