---
// QuoteParallax.astro - High-impact parallax section with a quote
---

<section class="quote-parallax-section relative overflow-hidden py-48 md:py-64">
  <!-- Background Image with Parallax -->
  <div class="parallax-bg absolute inset-0 z-0">
    <img 
      src="/architectural-depth.jpg" 
      alt="Architectural Depth" 
      class="w-full h-[120%] object-cover grayscale brightness-[0.25] contrast-[1.2]"
    />
  </div>

  <!-- Content Overlay -->
  <div class="absolute inset-0 z-10 bg-black/60"></div>
  <div class="absolute inset-0 z-10 bg-[radial-gradient(circle_at_center,rgba(255,115,0,0.15),transparent_70%)]"></div>

  <div class="container-fluid relative z-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <svg class="quote-icon w-12 h-12 mx-auto mb-12" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V12C14.017 12.5523 13.5693 13 13.017 13H11.017C10.4647 13 10.017 12.5523 10.017 12V9C10.017 8.44772 10.4647 8 11.017 8H12.017V5H11.017C8.80781 5 7.017 6.79086 7.017 9V15C7.017 16.1046 7.91243 17 9.017 17H12.017C12.5693 17 13.017 17.4477 13.017 18V21H14.017Z" />
      </svg>
      
      <h2 class="quote-text font-display text-[var(--step-2)] md:text-[var(--step-3)] font-bold leading-[1.2]">
        "Efficiency is doing things right; <span class="accent-text italic">effectiveness</span> is doing the right things."
      </h2>
      
      <div class="attribution mt-12 flex items-center justify-center gap-4">
        <div class="divider h-[1px] w-12"></div>
        <span class="text-[var(--step--1)] uppercase tracking-[0.4em] font-bold">Peter Drucker</span>
        <div class="divider h-[1px] w-12"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-parallax-section {
    background-color: #000 !important;
  }

  .parallax-bg {
    will-change: transform;
  }

  .quote-icon {
    color: rgba(255, 115, 0, 0.6) !important;
  }

  .quote-text {
    color: #ffffff !important;
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
  }

  .accent-text {
    color: #ff7300 !important;
  }

  .attribution {
    color: rgba(255, 255, 255, 0.6) !important;
  }

  .divider {
    background-color: rgba(255, 115, 0, 0.4) !important;
  }
</style>

<script>
  const initParallax = () => {
    const section = document.querySelector('.quote-parallax-section');
    const bg = section?.querySelector('.parallax-bg') as HTMLElement;
    
    if (!section || !bg) return;

    window.addEventListener('scroll', () => {
      const rect = section.getBoundingClientRect();
      const scrolled = window.scrollY;
      
      // Only calculate if section is in or near viewport
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        const speed = 0.2;
        const yPos = -(rect.top * speed);
        bg.style.transform = `translate3d(0, ${yPos}px, 0)`;
      }
    }, { passive: true });
  };

  document.addEventListener('DOMContentLoaded', initParallax);
  document.addEventListener('astro:page-load', initParallax);
</script>
