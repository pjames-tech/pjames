---
// Hero section - Refactored for proper alignment and clean CSS
interface FeatureCard {
  title: string;
  description: string;
}

const features: FeatureCard[] = [
  { title: "Authority Command", description: "Position yourself as the high-ticket prize." },
  { title: "Velocity Pipelines", description: "Systems that capture, qualify, and convert leads instantly." },
  { title: "Zero-Touch Closing", description: "AI infrastructure that nurtures and sells 24/7." },
];

const whatsappNumber = "2347033302085"; // Added if needed components
import ThreeHero from "../ui/ThreeHero.jsx";
---

<header id="top" class="hero-section">
  <!-- Background Image - Heavily Faded -->
  <div class="background-layer hidden"></div>

  <!-- Main Grid Container -->
  <div class="container-fluid hero-grid">
    
    <!-- Left Column: Content -->
    <div class="hero-content">
      <!-- Headline (Resend-Style One Liner) -->
      <h1 class="hero-headline">
        <span class="text-accent architect-glow">Scale </span> without friction.
      </h1>
      
      <!-- Description -->
      <p class="hero-description">
        Build high-yield systems that save cost & time with design, code and AI automation. Operate 10x faster and turn traffic into scalable revenue.
      </p>
      
      <!-- CTAs -->
      <div class="hero-actions">
        <button
          class="btn-primary-custom group action-book"
        >
          <span class="relative z-10">Get Started</span>
          <div class="btn-hover-overlay"></div>
        </button>
        <a
          href="#work"
          class="btn-secondary-custom"
        >
          See The System
          <span>→</span>
        </a>
      </div>
    </div>
    
    <!-- Right Column: 3D Element Container -->
    <div class="hero-3d-container">
      <ThreeHero client:only="react" />
    </div>
  </div>
</header>

<style>
  /* Base Layout */
  .hero-section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow-x: hidden;
    padding-block: clamp(1.2rem, 2.6vh, 2rem) clamp(1rem, 2vh, 1.6rem);
    will-change: transform;
  }

  @media (max-width: 767px) {
    .hero-section {
      align-items: flex-start;
      min-height: auto;
      padding-block: 2.4rem 1.2rem;
    }
  }

  /* Background */
  .background-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    opacity: 0.3;
  }

  .bg-radial {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgb(var(--bg)) 85%);
  }

  .bg-fade-bottom {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(var(--bg)) 0%, transparent 30%);
  }

  /* Grid Layout (Aligns with Global Container) */
  .hero-grid {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 520px);
    grid-template-areas: "content visual";
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
    max-width: 1200px;
    margin-inline: auto;
    min-height: clamp(560px, 74vh, 820px);
    padding-block: 0;
  }

  .hero-content {
    grid-area: content;
    display: flex;
    flex-direction: column;
    gap: clamp(1.1rem, 2vw, 1.9rem);
    text-align: left;
    align-items: flex-start;
    position: relative;
    z-index: 20;
    max-width: 42rem;
  }

  .hero-3d-container {
    grid-area: visual;
    position: relative;
    width: min(100%, 520px);
    height: clamp(320px, 34vw, 540px);
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: center;
    margin-inline: auto;
    overflow: visible;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  .hero-3d-container::before {
    content: "";
    position: absolute;
    inset: 12% 6%;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 34% 30%, rgb(var(--accent) / 0.2), transparent 56%),
      radial-gradient(circle at 68% 65%, rgb(var(--accent2) / 0.16), transparent 62%);
    filter: blur(24px);
  }

  /* Components */
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.45rem, 4.35vw + 1rem, 4.45rem);
    line-height: 1.02;
    letter-spacing: -0.045em;
    color: rgb(var(--text));
    max-width: 14ch;
    margin: 0;
  }

  .hero-description {
    font-size: clamp(1rem, 0.45vw + 0.7rem, 1.16rem);
    color: rgb(var(--text) / 0.85);
    max-width: 52ch;
    font-weight: 300;
    line-height: 1.65;
    margin: 0;
  }

  /* Buttons */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }

  .btn-primary-custom {
    position: relative;
    overflow: hidden;
    border-radius: 9999px;
    padding: 1rem 2rem;
    font-weight: 600;
    font-size: 1rem;
    text-align: center;
    background-color: rgb(var(--accent));
    color: white;
    transition: all 0.3s;
  }

  .btn-primary-custom:hover {
    transform: scale(1.05);
    box-shadow: 0 0 40px rgb(var(--accent) / 0.6);
  }

  .btn-hover-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(var(--text),0.2);
    transform: translateY(100%);
    transition: transform 0.3s;
  }

  .group:hover .btn-hover-overlay {
    transform: translateY(0);
  }

  .btn-secondary-custom {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 9999px;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 500;
    color: rgb(var(--text));
    border: 1px solid rgb(var(--border) / 0.2);
    background: rgb(var(--panel) / 0.9);
    transition: all 0.2s ease-out;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .btn-secondary-custom:hover {
    background: rgb(var(--panel));
    border-color: rgb(var(--accent) / 0.5);
    color: rgb(var(--accent));
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  /* Cards */
  .feature-card {
    padding: 1.25rem 1.5rem;
    border-radius: var(--radius-md, 12px);
    background: rgb(var(--panel) / 0.9);
    border: 1px solid rgb(var(--border) / 0.12);
    transition: all 0.2s ease-out;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .feature-card:hover {
    border-color: rgb(var(--accent) / 0.4);
    background: rgb(var(--panel));
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .feature-title {
    font-weight: 500;
    font-size: 1rem; /* Smaller title */
    color: rgb(var(--text));
    transition: color 0.3s;
    margin-bottom: 0.3rem;
  }

  .feature-desc {
  font-size: 0.85rem; /* Smaller desc */
  color: rgb(var(--text) / 0.8); /* Increased opacity */
  line-height: 1.4;
  font-weight: 400; /* Increased weight */
}

  /* ========================================
     MOBILE RESPONSIVE (< 768px)
     ======================================== */
  @media (max-width: 767px) {
    .hero-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "visual"
        "content";
      gap: 1.5rem;
      min-height: auto;
      padding-top: 0;
    }

    .hero-content {
      order: 2;
      align-items: center;
      text-align: center;
      max-width: 100%;
      gap: 1.1rem;
    }

    .hero-headline {
      max-width: 11.5ch;
      font-size: clamp(2.25rem, 10vw, 3.15rem);
      line-height: 1.05;
    }

    .hero-description {
      max-width: 42ch;
      font-size: 0.98rem;
      line-height: 1.6;
      margin-inline: auto;
    }

    /* Full-width stacked CTAs on mobile */
    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
      gap: 0.75rem;
      margin-top: 0.35rem;
      margin-inline: auto;
      align-items: center;
    }

    .btn-primary-custom,
    .btn-secondary-custom {
      width: 100%;
      justify-content: center;
      padding: 0.95rem 1.4rem;
    }

    .hero-3d-container {
      order: 1;
      height: clamp(260px, 62vw, 340px);
      min-height: 260px;
      margin-top: 0;
      margin-bottom: 0.35rem;
    }

    .hero-features {
      display: none;
    }

    .feature-title {
      font-size: 0.9rem;
    }

    .feature-desc {
      font-size: 0.8rem;
    }
  }

  /* Tablet (768px - 1023px) */
  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "content"
        "visual";
      gap: 2.5rem;
      min-height: auto;
    }

    .hero-content {
      align-items: center;
      text-align: center;
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-3d-container {
      height: clamp(360px, 46vw, 470px);
      max-width: 560px;
      margin-inline: auto;
    }

    .hero-features {
      max-width: 500px;
      margin-inline: auto;
    }
  }
</style>

<script>
  // Smooth scroll to section center
  const initSmoothScroll = () => {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (!href || href === '#') return;
        
        const target = document.querySelector(href);
        if (!target) return;
        
        e.preventDefault();
        
        // Calculate position to scroll to CENTER of viewport
        const targetRect = target.getBoundingClientRect();
        const targetHeight = targetRect.height;
        const viewportHeight = window.innerHeight;
        
        // Always center the target, even if it's tall
        const centerOffset = (viewportHeight - targetHeight) / 2;
        const scrollPosition = target.offsetTop - centerOffset;
        
        if ((window as any).lenis) {
          (window as any).lenis.scrollTo(Math.max(0, scrollPosition), {
            duration: 1.5,
            easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // Exponential easing
          });
        } else {
          window.scrollTo({
            top: Math.max(0, scrollPosition),
            behavior: 'smooth'
          });
        }
      });
    });
  };

  document.addEventListener('DOMContentLoaded', initSmoothScroll);
  document.addEventListener('astro:page-load', initSmoothScroll);
</script>
