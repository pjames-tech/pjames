---
const businessHours = { start: 8, end: 19 };
const lagosHour = Number(
  new Intl.DateTimeFormat("en-GB", {
    hour: "2-digit",
    hour12: false,
    timeZone: "Africa/Lagos"
  }).format(new Date())
);
const isAvailableNow = lagosHour >= businessHours.start && lagosHour < businessHours.end;
const availabilityState = isAvailableNow ? "AVAILABLE" : "ASYNC_QUEUE";
const availabilityNote = isAvailableNow
  ? "Response Window: <24H (WAT)"
  : "System Queue: <24H (WAT)";
---

<section id="about" class="pt-0 pb-24 container-fluid">
  <div class="mb-12 text-center">
    <p class="text-[var(--step--1)] uppercase tracking-[0.18em] text-[rgb(var(--accent))] font-medium mb-3">
      Strategic Operator
    </p>
    <h2 class="font-display font-bold text-[var(--step-3)] leading-[1.1]">
      The Architect.
    </h2>
  </div>

  <div class="about-dashboard max-w-6xl mx-auto grid gap-6 lg:grid-cols-[1.35fr_1fr]">
    <article class="bento-card group backdrop-blur-md p-6 md:p-8 lg:p-10">
      <div class="grid gap-8 md:grid-cols-[220px_1fr] items-center">
        <div class="profile-image-container">
          <img
            src="/profile.png"
            alt="P. James - Systems Architect and AI Brand Technologist"
            class="profile-image"
          />
          <span class="profile-corner corner-tl"></span>
          <span class="profile-corner corner-tr"></span>
          <span class="profile-corner corner-bl"></span>
          <span class="profile-corner corner-br"></span>
          <div class="profile-scanline"></div>
          <div class="profile-feed font-mono">
            <span class="feed-dot"></span>
            <span>Active</span>
          </div>
          <div class="profile-glow"></div>
        </div>

        <div class="text-center md:text-left flex-1">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[rgb(var(--accent))] mb-2">
            Systems Architect / AI Brand Technologist
          </p>
          <h3 class="font-display font-bold text-[var(--step-2)] text-text mb-3">
            P. James
          </h3>

          <div
            class="about-status-badge"
            data-availability-badge
            data-state={isAvailableNow ? "available" : "queued"}
          >
            <span class="about-status-dot"></span>
            <span class="about-status-text">
              STATUS: <span data-availability-state>{availabilityState}</span>
            </span>
          </div>

          

          <p class="text-[var(--step-0)] text-muted leading-relaxed mb-4">
            I architect digital ecosystems engineered for high-velocity growth. Where others see pages, I see revenue pipelines.
          </p>
          <p class="text-text font-medium text-lg">
            Clarity converts, confusion costs.
          </p>
          <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted/70 mt-4" data-availability-note>
            {availabilityNote}
          </p>
        </div>
      </div>
    </article>

    <aside class="bento-card spec-card group/spec backdrop-blur-md p-6 md:p-8">
      <div class="flex items-center gap-3 mb-8">
        <span class="spec-chip font-mono">[ SYSTEM_CORE_COMPETENCIES ]</span>
        <div class="h-px bg-border/20 flex-1"></div>
      </div>

      <div class="space-y-4">
        <div class="spec-row spec-row--primary" style="--fill: 98%;">
          <div class="spec-row-top">
            <span class="spec-index">01 // AUTOMATION</span>
            <span class="spec-percent">98%</span>
          </div>
          <p class="spec-label">Autonomous Pipelines (Automation)</p>
          <div class="spec-meter"><span></span></div>
        </div>

        <div class="spec-row" style="--fill: 91%;">
          <div class="spec-row-top">
            <span class="spec-index">02 // CODE</span>
            <span class="spec-percent">91%</span>
          </div>
          <p class="spec-label">Scalable Architecture (Code)</p>
          <div class="spec-meter"><span></span></div>
        </div>

        <div class="spec-row" style="--fill: 88%;">
          <div class="spec-row-top">
            <span class="spec-index">03 // DESIGN</span>
            <span class="spec-percent">88%</span>
          </div>
          <p class="spec-label">Visual Authority (Design)</p>
          <div class="spec-meter"><span></span></div>
        </div>
      </div>
    </aside>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("#about");
    if (!root) return;

    const stateTarget = root.querySelector("[data-availability-state]");
    const noteTarget = root.querySelector("[data-availability-note]");
    const badgeTarget = root.querySelector("[data-availability-badge]");

    if (!stateTarget || !noteTarget || !badgeTarget) return;

    const inOfficeHours = () => {
      const formattedHour = new Intl.DateTimeFormat("en-GB", {
        hour: "2-digit",
        hour12: false,
        timeZone: "Africa/Lagos"
      }).format(new Date());
      const hour = Number(formattedHour);
      return hour >= 8 && hour < 19;
    };

    const syncAvailability = () => {
      const active = inOfficeHours();
      stateTarget.textContent = active ? "AVAILABLE" : "ASYNC_QUEUE";
      noteTarget.textContent = active ? "Response Window: <24H (WAT)" : "System Queue: <24H (WAT)";
      badgeTarget.setAttribute("data-state", active ? "available" : "queued");
    };

    syncAvailability();
    window.setInterval(syncAvailability, 60000);
  })();
</script>

<style>
  .about-dashboard {
    align-items: stretch;
  }

  .bento-card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg, 24px);
    border: 1px solid rgb(var(--border) / 0.16);
    background: linear-gradient(155deg, rgb(var(--panel) / 0.94), rgb(var(--panel2) / 0.84));
    backdrop-filter: blur(12px);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .bento-card::before {
    content: "";
    position: absolute;
    inset: 0;
    padding: 1px;
    border-radius: inherit;
    background: linear-gradient(
      115deg,
      rgb(var(--accent) / 0),
      rgb(var(--accent) / 0.5),
      rgb(var(--accent) / 0)
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .bento-card:hover {
    border-color: rgb(var(--accent) / 0.26);
    box-shadow: 0 24px 45px -22px rgb(var(--accent) / 0.42);
    transform: translateY(-2px);
  }

  .bento-card:hover::before {
    opacity: 1;
  }

  .profile-image-container {
    position: relative;
    width: min(100%, 220px);
    aspect-ratio: 1 / 1;
    margin-inline: auto;
    padding: 0.55rem;
    border-radius: var(--radius-md, 20px);
    border: 1px solid rgb(var(--accent) / 0.22);
    background: linear-gradient(145deg, rgb(var(--panel2) / 0.9), rgb(var(--panel) / 0.5));
    isolation: isolate;
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: calc(var(--radius-md, 20px) - 4px);
    border: 1px solid rgb(var(--border) / 0.22);
    filter: saturate(0.72) contrast(1.04);
    transition: filter 0.5s ease;
  }

  .group:hover .profile-image {
    filter: saturate(1) contrast(1.08);
  }

  .profile-scanline {
    position: absolute;
    inset: 0.55rem;
    border-radius: calc(var(--radius-md, 20px) - 4px);
    background: repeating-linear-gradient(
      to bottom,
      transparent 0 13px,
      rgb(var(--accent) / 0.08) 13px 15px
    );
    mix-blend-mode: screen;
    pointer-events: none;
    opacity: 0.45;
    animation: scanDrift 6s linear infinite;
  }

  .profile-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    pointer-events: none;
  }

  .corner-tl {
    top: 0.45rem;
    left: 0.45rem;
    border-top: 2px solid rgb(var(--accent) / 0.8);
    border-left: 2px solid rgb(var(--accent) / 0.8);
    border-top-left-radius: 8px;
  }

  .corner-tr {
    top: 0.45rem;
    right: 0.45rem;
    border-top: 2px solid rgb(var(--accent) / 0.8);
    border-right: 2px solid rgb(var(--accent) / 0.8);
    border-top-right-radius: 8px;
  }

  .corner-bl {
    bottom: 0.45rem;
    left: 0.45rem;
    border-bottom: 2px solid rgb(var(--accent) / 0.8);
    border-left: 2px solid rgb(var(--accent) / 0.8);
    border-bottom-left-radius: 8px;
  }

  .corner-br {
    bottom: 0.45rem;
    right: 0.45rem;
    border-bottom: 2px solid rgb(var(--accent) / 0.8);
    border-right: 2px solid rgb(var(--accent) / 0.8);
    border-bottom-right-radius: 8px;
  }

  .profile-feed {
    position: absolute;
    left: 0.9rem;
    bottom: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.28rem 0.52rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--accent) / 0.3);
    background: rgb(var(--panel) / 0.8);
    color: rgb(var(--text) / 0.9);
    font-size: 0.58rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .feed-dot {
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: rgb(var(--accent));
    box-shadow: 0 0 10px rgb(var(--accent) / 0.55);
    animation: feedBlink 2.8s ease-in-out infinite;
  }

  .profile-glow {
    position: absolute;
    inset: -10px;
    background: radial-gradient(circle at center, rgb(var(--accent) / 0.28), transparent 70%);
    z-index: -1;
    opacity: 0.58;
    transform: scale(0.92);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .group:hover .profile-glow {
    opacity: 1;
    transform: scale(1);
  }

  .about-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--border) / 0.18);
    background: rgb(var(--panel) / 0.82);
    padding: 0.35rem 0.9rem;
    margin-bottom: 1rem;
  }

  .about-status-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    animation: statusPulse 2.6s ease-in-out infinite;
  }

  .about-status-badge[data-state="available"] .about-status-dot {
    background: #39ff79;
    box-shadow: 0 0 8px rgba(57, 255, 121, 0.38);
  }

  .about-status-badge[data-state="queued"] .about-status-dot {
    background: #ffc857;
    box-shadow: 0 0 8px rgba(255, 200, 87, 0.3);
  }

  .about-status-text {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: rgb(var(--text) / 0.85);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  .spec-card {
    height: 100%;
  }

  .spec-chip {
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--accent));
    background: rgb(var(--accent) / 0.1);
    border: 1px solid rgb(var(--accent) / 0.26);
    padding: 0.28rem 0.45rem;
    border-radius: 0.4rem;
  }

  .spec-row {
    border: 1px solid rgb(var(--border) / 0.16);
    border-radius: 14px;
    padding: 0.82rem 0.9rem;
    background: rgb(var(--panel2) / 0.36);
    transition: border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
  }

  .spec-row-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.32rem;
  }

  .spec-index,
  .spec-percent,
  .spec-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .spec-index {
    font-size: 0.64rem;
    color: rgb(var(--text) / 0.68);
  }

  .spec-percent {
    font-size: 0.7rem;
    color: rgb(var(--accent));
  }

  .spec-label {
    font-size: 0.62rem;
    color: rgb(var(--text) / 0.86);
    margin-bottom: 0.55rem;
  }

  .spec-meter {
    height: 7px;
    border-radius: 999px;
    background: rgb(var(--border) / 0.14);
    overflow: hidden;
  }

  .spec-meter > span {
    display: block;
    height: 100%;
    width: var(--fill);
    border-radius: inherit;
    background: linear-gradient(90deg, rgb(var(--accent) / 0.55), rgb(var(--accent)));
    opacity: 0.86;
  }

  .spec-row--primary {
    border-color: rgb(var(--accent) / 0.38);
    background: linear-gradient(130deg, rgb(var(--accent) / 0.13), rgb(var(--panel2) / 0.3));
    box-shadow: 0 14px 32px -22px rgb(var(--accent) / 0.7);
  }

  .spec-row--primary .spec-index,
  .spec-row--primary .spec-label {
    color: rgb(var(--text) / 0.94);
  }

  .spec-row--primary .spec-percent {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .spec-row--primary .spec-meter {
    height: 10px;
  }

  .spec-row--primary .spec-meter > span {
    opacity: 1;
  }

  .group\/spec:hover .spec-row {
    border-color: rgb(var(--accent) / 0.25);
  }

  @keyframes statusPulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.07);
      opacity: 1;
    }
  }

  @keyframes scanDrift {
    from {
      transform: translateY(-4px);
    }
    to {
      transform: translateY(4px);
    }
  }

  @keyframes feedBlink {
    0%,
    100% {
      opacity: 0.55;
    }
    50% {
      opacity: 1;
    }
  }

  @media (max-width: 767px) {
    .profile-image-container {
      width: min(100%, 230px);
    }

    .spec-chip {
      font-size: 0.6rem;
    }
  }
</style>
