---
// About section - "AI Brand Technologist" Profile
// Refactored: Process steps moved to dedicated Process.astro component
---

<section id="about" class="pt-0 pb-24 container-fluid">
  <!-- Section Header -->
  <div class="mb-12 text-center">
    <p class="text-[var(--step--1)] uppercase tracking-[0.18em] text-[rgb(var(--accent))] font-medium mb-3">
      The Mind Behind
    </p>
    <div class="about-status-badge">
      <span class="about-status-dot animate-pulse"></span>
      <span class="about-status-text">AI Brand Technologist • Available</span>
    </div>
    <h2 class="font-display font-bold text-[var(--step-3)] leading-[1.1]">
      The Architect.
    </h2>
  </div>
  
  <!-- Single Profile Card (Centered) -->
  <div class="max-w-4xl mx-auto">
    
    <div class="bento-card group flex flex-col md:flex-row items-center gap-8 md:gap-12 p-8 md:p-12">
      <!-- Photo -->
      <div class="profile-image-container flex-shrink-0">
        <img
          src="/profile.jpg"
          alt="P. James - AI Brand Technologist"
          class="profile-image"
        />
        <div class="profile-glow"></div>
      </div>
      
      <!-- Bio Content -->
      <div class="text-center md:text-left flex-1">
        <h3 class="font-display font-bold text-[var(--step-2)] text-text mb-2">
          P. James | AI Brand Technologist
        </h3>
        
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 text-sm mb-6">
          <div class="flex items-center gap-1.5 text-[rgb(var(--accent))] font-medium px-3 py-1 rounded-full bg-[rgb(var(--accent)/0.1)] border border-[rgb(var(--accent)/0.2)]">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <span>Based in Nigeria</span>
          </div>
          <span class="text-muted hidden md:inline">•</span>
          <span class="text-muted">Active Globally</span>
        </div>
        
        <p class="text-[var(--step-0)] text-muted leading-relaxed mb-8">
          You don't just need a graphic designer, you need someone who understands systems. 
          I bridge the gap between visual identity and technical infrastructure, 
          architecting digital ecosystems engineered for growth. Where others see "pages", I see pipelines.
          <br class="hidden md:block" />
          <span class="text-text font-medium text-lg block mt-2">Clarity converts, confusion costs.</span>
        </p>

      </div>
    </div>
    
    <!-- THE TRINITY: Competence Stack -->
      <div class="flex items-center gap-3 mb-8">
        <span class="text-[10px] font-mono uppercase tracking-widest text-[#FF7300] bg-[#FF7300]/10 px-2 py-1 rounded">The Trinity</span>
        <div class="h-px bg-border/20 flex-1"></div>
      </div>

      <div class="space-y-6">
        
        <!-- 1. DESIGN -->
        <div class="group/stack">
          <div class="flex items-center justify-between mb-2">
            <span class="font-mono text-xs text-[#FF7300] font-bold tracking-wider">01 // DESIGN</span>
            <span class="text-[10px] text-muted uppercase tracking-widest">Visual Authority</span>
          </div>
          <div class="relative h-1.5 bg-panel2 rounded-full overflow-hidden mb-3">
            <div class="absolute inset-y-0 left-0 w-[95%] bg-[#FF7300] rounded-full opacity-80 group-hover/stack:opacity-100 transition-opacity"></div>
          </div>
          <p class="text-base text-muted">
            <span class="text-text font-medium block sm:inline">I design interfaces that build instant trust.</span>
            <span class="text-sm text-muted/60 block sm:inline sm:ml-1">// UI/UX, Identity Systems</span>
          </p>
        </div>

        <!-- 2. CODE -->
        <div class="group/stack">
          <div class="flex items-center justify-between mb-2">
            <span class="font-mono text-xs text-[#FF7300] font-bold tracking-wider">02 // CODE</span>
            <span class="text-[10px] text-muted uppercase tracking-widest">Full-Stack Arch</span>
          </div>
          <div class="relative h-1.5 bg-panel2 rounded-full overflow-hidden mb-3">
            <div class="absolute inset-y-0 left-0 w-[90%] bg-[#FF7300] rounded-full opacity-80 group-hover/stack:opacity-100 transition-opacity"></div>
          </div>
          <p class="text-base text-muted">
            <span class="text-text font-medium block sm:inline">I build speed, security, and scalability.</span>
            <span class="text-sm text-muted/60 block sm:inline sm:ml-1">// Next.js, Astro, TS</span>
          </p>
        </div>

        <!-- 3. AUTOMATION -->
        <div class="group/stack">
          <div class="flex items-center justify-between mb-2">
            <span class="font-mono text-xs text-[#FF7300] font-bold tracking-wider">03 // AUTOMATION</span>
            <span class="text-[10px] text-muted uppercase tracking-widest">AI Agents</span>
          </div>
          <div class="relative h-1.5 bg-panel2 rounded-full overflow-hidden mb-3">
            <div class="absolute inset-y-0 left-0 w-[100%] bg-[#FF7300] rounded-full opacity-80 group-hover/stack:opacity-100 transition-opacity"></div>
          </div>
          <p class="text-base text-muted">
            <span class="text-text font-medium block sm:inline">I engineer systems that sell while you sleep.</span>
            <span class="text-sm text-muted/60 block sm:inline sm:ml-1">// LLMs, Workflows, n8n</span>
          </p>
        </div>

      </div>
    </div>
    
  </div>
</section>

<style>
  /* Bento Card Base */
  .bento-card {
    background: rgb(var(--panel));
    border: 1px solid rgb(var(--border) / 0.1);
    border-radius: var(--radius-lg, 24px);
    transition: all 0.3s ease-out;
  }

  .bento-card:hover {
    border-color: rgb(var(--accent) / 0.3);
    box-shadow: 0 20px 40px -10px rgb(var(--border) / 0.1);
    transform: translateY(-2px);
  }

  /* Profile Image */
  .profile-image-container {
    position: relative;
    width: 200px;
    height: 200px;
  }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md, 20px);
    border: 1px solid rgb(var(--border) / 0.1);
    filter: grayscale(100%);
    transition: filter 0.5s;
  }
  
  .group:hover .profile-image {
    filter: grayscale(0%);
  }

  .profile-glow {
    position: absolute;
    inset: -8px;
    background: radial-gradient(circle at center, rgb(var(--accent) / 0.3), transparent 70%);
    border-radius: 50%;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.5s, transform 0.5s;
    transform: scale(0.8);
  }

  .group:hover .profile-glow {
    opacity: 1;
    transform: scale(1);
  }

  .about-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 9999px;
    border: 1px solid rgb(var(--border) / 0.15);
    background: rgb(var(--panel) / 0.9);
    padding: 0.35rem 0.9rem;
    margin-bottom: 0.9rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .about-status-dot {
    height: 0.4rem;
    width: 0.4rem;
    border-radius: 9999px;
    background-color: #2eff2e;
    box-shadow: 0 0 8px rgba(46, 255, 46, 0.5);
  }

  .about-status-text {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: rgba(var(--text), 0.8);
    font-weight: 500;
  }
</style>
