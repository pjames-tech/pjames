---
interface Tool {
  name: string;
  logo: string;
  fallbackLogo?: string;
}

interface ToolGroup {
  title: string;
  tools: Tool[];
}

const si = (slug: string) => `https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/${slug}.svg`;
const favicon = (domain: string) => `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;

const toolGroups: ToolGroup[] = [
  {
    title: "Design",
    tools: [
      { name: "Photoshop", logo: si("adobephotoshop"), fallbackLogo: favicon("photoshop.adobe.com") },
      { name: "Illustrator", logo: si("adobeillustrator"), fallbackLogo: favicon("illustrator.adobe.com") },
      { name: "InDesign", logo: si("adobeindesign"), fallbackLogo: favicon("indesign.adobe.com") },
      { name: "After Effects", logo: si("adobeaftereffects"), fallbackLogo: favicon("aftereffects.adobe.com") },
      { name: "Lottie", logo: si("lottiefiles"), fallbackLogo: favicon("lottiefiles.com") },
      { name: "Figma", logo: si("figma"), fallbackLogo: favicon("figma.com") },
      { name: "Canva Pro", logo: si("canva"), fallbackLogo: favicon("canva.com") },
    ],
  },
  {
    title: "Code",
    tools: [
      { name: "React", logo: si("react"), fallbackLogo: favicon("react.dev") },
      { name: "Node.js", logo: si("nodedotjs"), fallbackLogo: favicon("nodejs.org") },
      { name: "Next.js", logo: si("nextdotjs"), fallbackLogo: favicon("nextjs.org") },
      { name: "Astro", logo: si("astro"), fallbackLogo: favicon("astro.build") },
      { name: "TypeScript", logo: si("typescript"), fallbackLogo: favicon("typescriptlang.org") },
      { name: "Python", logo: si("python"), fallbackLogo: favicon("python.org") },
      {
        name: "React Native",
        logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/reactnative/reactnative-original.svg",
        fallbackLogo: favicon("reactnative.dev"),
      },
      { name: "Expo", logo: si("expo"), fallbackLogo: favicon("expo.dev") },
      { name: "Firebase", logo: si("firebase"), fallbackLogo: favicon("firebase.google.com") },
      { name: "Express", logo: si("express"), fallbackLogo: favicon("expressjs.com") },
      { name: "NestJS", logo: si("nestjs"), fallbackLogo: favicon("nestjs.com") },
      { name: "FastAPI", logo: si("fastapi"), fallbackLogo: favicon("fastapi.tiangolo.com") },
      { name: "Django", logo: si("django"), fallbackLogo: favicon("djangoproject.com") },
      { name: "GraphQL", logo: si("graphql"), fallbackLogo: favicon("graphql.org") },
      { name: "PostgreSQL", logo: si("postgresql"), fallbackLogo: favicon("postgresql.org") },
      { name: "MySQL", logo: si("mysql"), fallbackLogo: favicon("mysql.com") },
      { name: "MongoDB", logo: si("mongodb"), fallbackLogo: favicon("mongodb.com") },
      { name: "Redis", logo: si("redis"), fallbackLogo: favicon("redis.io") },
      { name: "Prisma", logo: si("prisma"), fallbackLogo: favicon("prisma.io") },
      { name: "Supabase", logo: si("supabase"), fallbackLogo: favicon("supabase.com") },
    ],
  },
  {
    title: "Automation",
    tools: [
      { name: "n8n", logo: si("n8n"), fallbackLogo: favicon("n8n.io") },
      { name: "Zapier", logo: si("zapier"), fallbackLogo: favicon("zapier.com") },
      { name: "Make.com", logo: si("make"), fallbackLogo: favicon("make.com") },
      { name: "ManyChat", logo: favicon("manychat.com") },
      { name: "LangChain", logo: si("langchain"), fallbackLogo: favicon("langchain.com") },
      { name: "Vercel AI SDK", logo: si("vercel"), fallbackLogo: favicon("vercel.com") },
      { name: "OpenAI", logo: si("openai"), fallbackLogo: favicon("openai.com") },
    ],
  },
];
---

<section id="infrastructure" class="py-36 container-fluid">
  <div class="mb-12 max-w-3xl">
    <p class="text-[var(--step--1)] uppercase tracking-[0.25em] text-[rgb(var(--accent))] font-bold mb-3">
      The Technical Bedrock
    </p>
    <h2 class="font-display font-bold text-[var(--step-3)] leading-[1.1]">
      The right tools, selected for <span class="text-[rgb(var(--accent))]">your scale</span>.
    </h2>
    <p class="mt-5 text-muted leading-relaxed">
      With experience across a wide range of design, coding, and automation platforms, I use the right tools for each project so you do not have to worry about scaling needs later.
    </p>
  </div>

  <div class="space-y-6">
    {toolGroups.map((group) => (
      <div class="tool-group">
        <h3 class="group-title">{group.title} Tools</h3>
        <div class="tool-grid">
          {group.tools.map((tool) => (
            <div class="tool-chip">
              <img
                src={tool.logo}
                data-fallback={tool.fallbackLogo}
                alt={`${tool.name} logo`}
                width="22"
                height="22"
                loading="lazy"
                decoding="async"
                onerror="if (this.dataset.fallback && this.src !== this.dataset.fallback) { this.src = this.dataset.fallback; }"
              />
              <span>{tool.name}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .tool-group {
    background: rgb(var(--panel));
    border: 1px solid rgb(var(--border) / 0.1);
    border-radius: var(--radius-lg, 16px);
    padding: var(--space-4);
  }

  .group-title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgb(var(--accent));
    margin-bottom: 1rem;
  }

  .tool-grid {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(auto-fit, minmax(min(11rem, 100%), 1fr));
  }

  .tool-chip {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 0.75rem;
    border-radius: 0.75rem;
    border: 1px solid rgb(var(--border) / 0.14);
    background: rgb(var(--panel2) / 0.6);
    color: rgb(var(--text));
    font-size: 0.87rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .tool-chip img {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    background: #ffffff;
    border-radius: 0.25rem;
    padding: 0.1rem;
    object-fit: contain;
  }

  .tool-chip:hover {
    border-color: rgb(var(--accent) / 0.3);
    transform: translateY(-1px);
  }
</style>
