---
// Infrastructure section - Technical Authority Pillars
interface Pillar {
  icon: string;
  title: string;
  body: string;
}

const pillars: Pillar[] = [
  {
    icon: "design",
    title: "Brand Systems",
    body: "High-ticket aesthetic meets conversion-optimized UI. I design identity systems that command authority and turn casual visitors into loyal clients.",
  },
  {
    icon: "code",
    title: "Performance Engineering",
    body: "Bespoke engineering tailored to your needs. I choose the specific stack—whether Next.js, React, or TypeScript—that guarantees ultimate performance for your project.",
  },
  {
    icon: "automation",
    title: "Revenue Automation",
    body: "Intelligent workflows that work while you sleep. Automated lead capture, AI qualification, and revenue engines that drive growth on autopilot.",
  },
];
---

<section id="infrastructure" class="py-36 container-fluid">
  <div class="mb-12">
    <p class="text-[var(--step--1)] uppercase tracking-[0.25em] text-[rgb(var(--accent))] font-bold mb-3">
      The Infrastructure
    </p>
    <h2 class="font-display font-bold text-[var(--step-3)] leading-[1.1]">
      Engineered for speed, <br />
      built for <span class="text-[rgb(var(--accent))]">revenue</span>.
    </h2>
  </div>
  
  <div class="grid gap-6 [grid-template-columns:repeat(auto-fit,minmax(min(18rem,100%),1fr))]">
    {pillars.map((pillar) => (
      <div class="pillar-card group">
        <!-- Icon -->
        <div class="icon-container">
          {pillar.icon === "design" && (
            <svg xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:cc="http://creativecommons.org/ns#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:svg="http://www.w3.org/2000/svg" xmlns="http://www.w3.org/2000/svg" xmlns:sodipodi="http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd" xmlns:inkscape="http://www.inkscape.org/namespaces/inkscape" viewBox="0 0 30 30" version="1.1" id="svg822" inkscape:version="0.92.4 (f8dce91, 2019-08-02)" sodipodi:docname="design.svg" fill="#000000"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <defs id="defs816"> <inkscape:path-effect only_selected="false" apply_with_weight="true" apply_no_weight="true" helper_size="0" steps="2" weight="33.333333" is_visible="true" id="path-effect1025" effect="bspline"></inkscape:path-effect> <inkscape:path-effect only_selected="false" apply_with_weight="true" apply_no_weight="true" helper_size="0" steps="2" weight="33.333333" is_visible="true" id="path-effect1021" effect="bspline"></inkscape:path-effect> </defs> <sodipodi:namedview id="base" pagecolor="#ff7300fffff" bordercolor="#666666" borderopacity="1.0" inkscape:pageopacity="0.0" inkscape:pageshadow="2" inkscape:zoom="17.833333" inkscape:cx="19.485981" inkscape:cy="13.037383" inkscape:document-units="px" inkscape:current-layer="layer1" showgrid="true" units="px" inkscape:window-width="1366" inkscape:window-height="713" inkscape:window-x="0" inkscape:window-y="0" inkscape:window-maximized="1" showguides="false" inkscape:guide-bbox="true"> <sodipodi:guide position="21.126168,22.794393" orientation="1,0" id="guide1575" inkscape:locked="false"></sodipodi:guide> <sodipodi:guide position="22.682243,23.285047" orientation="1,0" id="guide1635" inkscape:locked="false"></sodipodi:guide> <sodipodi:guide position="22.682243,7.6455921" orientation="0,1" id="guide1639" inkscape:locked="false"></sodipodi:guide> <sodipodi:guide position="18.859863,18.859863" orientation="1,0" id="guide1242" inkscape:locked="false"></sodipodi:guide> <inkscape:grid type="xygrid" id="grid1103"></inkscape:grid> </sodipodi:namedview> <metadata id="metadata819"> <rdf:rdf> <cc:work rdf:about=""> <dc:format>image/svg+xml</dc:format> <dc:type rdf:resource="http://purl.org/dc/dcmitype/StillImage"></dc:type> <dc:title></dc:title> </cc:work> </rdf:rdf> </metadata> <g inkscape:label="Layer 1" inkscape:groupmode="layer" id="layer1" transform="translate(0,-289.0625)"> <path style="opacity:1;fill:#ff7300;fill-opacity:1;stroke:none;stroke-width:2;stroke-miterlimit:4;stroke-dasharray:none;stroke-opacity:1" d="M 8.2832031,5.453125 5.453125,8.2832031 6.515625,9.34375 7.9296875,7.9296875 8.6367188,8.6367188 7.2226562,10.050781 l 1.4140626,1.414063 1.4140622,-1.414063 0.707031,0.707031 -1.414062,1.414063 1.414062,1.414063 2.828126,-2.828126 z M 21.283203,5.8886719 18.617188,8.5546875 21.445312,11.382812 24.111328,8.7167969 C 23.72822,8.1781369 23.307331,7.6589012 22.824219,7.1757812 22.341109,6.6926712 21.821837,6.2718019 21.283203,5.8886719 Z M 17.203125,9.96875 6.5957031,20.576172 5.8886719,24.111328 9.4238281,23.404297 20.03125,12.796875 Z m 2.039063,6.445312 -2.828126,2.828126 1.414063,1.414062 1.414063,-1.414062 0.707031,0.707031 -1.414063,1.414062 1.414063,1.414063 1.414062,-1.414063 0.707031,0.707031 -1.414062,1.414063 1.060547,1.0625 2.830078,-2.830078 z" transform="translate(0,289.0625)" id="rect1114" inkscape:connector-curvature="0"></path> </g> </g></svg>
          )}
          {pillar.icon === "code" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          )}
          {pillar.icon === "automation" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          )}
        </div>
        
        <!-- Content -->
        <h3 class="font-display font-bold text-xl text-text mb-3 group-hover:text-[rgb(var(--accent))] transition-colors">
          {pillar.title}
        </h3>
        <p class="text-muted leading-relaxed">
          {pillar.body}
        </p>
      </div>
    ))}
  </div>
</section>

<style>
  .pillar-card {
    background: rgb(var(--panel));
    border: 1px solid rgb(var(--border) / 0.1);
    border-radius: var(--radius-lg, 16px);
    padding: var(--space-4);
    transition: all 0.2s ease-out;
  }

  .pillar-card:hover {
    border-color: rgb(var(--accent) / 0.3);
    transform: translateY(-2px);
  }

  .icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-md, 12px);
    background: rgb(var(--accent) / 0.1);
    color: rgb(var(--accent));
    margin-bottom: 1.5rem;
  }

  .pillar-card:hover .icon-container {
    background: rgb(var(--accent) / 0.2);
  }
</style>
