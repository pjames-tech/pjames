          )}
          {pillar.icon === "code" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          )}
          {pillar.icon === "automation" && (
            <svg viewBox="0 -0.5 134 134" fill="none" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M37.8932 42.7875C46.3599 63.134 55.1496 84.2621 64.0699 105.703C70.0064 107.099 71.3132 108.453 72.1428 115.109C72.5363 118.254 72.7541 121.418 72.7952 124.586C72.8648 130.335 70.4541 133 64.7334 132.933C54.9022 132.817 45.0755 132.299 35.2448 132.07C31.3199 131.979 27.3819 132.104 23.461 132.326C20.5324 132.492 18.8666 131.73 18.631 128.873C18.0972 123.441 17.91 117.98 18.0704 112.524C18.2772 107.978 21.19 105.76 25.9944 105.447C27.5184 105.347 29.0536 105.397 30.5835 105.389C32.101 105.382 33.6184 105.389 35.676 105.389C34.5793 101.445 33.6841 97.8031 32.5525 94.2359C28.4951 81.4471 24.3575 68.6834 20.2488 55.9104C20.1176 55.4949 19.9318 55.0932 19.8261 54.6718C19.0845 51.7098 19.0707 48.2292 17.4141 45.9307C15.896 43.8245 12.4994 43.1577 10.1202 41.572C-2.30557 33.2897 -3.09316 13.4151 8.57193 4.05769C15.9767 -1.88282 29.154 -1.23308 37.1882 5.56329C38.8045 6.8652 40.2233 8.39493 41.4 10.1045C41.813 10.8636 42.4488 11.4777 43.2218 11.864C43.9947 12.2504 44.8676 12.3904 45.7226 12.2652C58.575 11.3647 71.4406 10.6309 84.2818 9.59458C92.041 8.96843 92.0266 8.76757 94.7996 15.9879C98.6352 15.5456 102.502 15.1689 106.34 14.5959C107.072 14.4863 107.814 13.7019 108.336 13.0548C110.46 10.4202 112.52 7.73183 114.571 5.03691C117.242 1.52353 119.618 0.851447 123.69 2.62684C125.814 3.49406 127.884 4.48761 129.889 5.60207C132.243 6.98366 133.025 9.1916 132.163 11.1153C131.31 13.0187 129.115 13.9172 126.545 13.2004C125.169 12.8464 123.858 12.2769 122.66 11.513C120.785 10.2476 119.51 10.7011 118.239 12.3557C117.339 13.4559 116.372 14.4991 115.344 15.4793C111.962 18.9047 111.777 22.0873 114.647 25.9807C116.721 28.7937 118.734 31.6503 120.686 34.5505C121.703 36.0601 122.842 36.3915 124.58 35.8251C126.426 35.1549 1