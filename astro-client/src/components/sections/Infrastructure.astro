---
// Infrastructure section - Technical Authority Pillars
interface Pillar {
  icon: string;
  title: string;
  body: string;
}

const pillars: Pillar[] = [
  {
    icon: "design",
    title: "Brand Systems",
    body: "High-ticket aesthetic meets conversion-optimized UI. I design identity systems that command authority and turn casual visitors into loyal clients.",
  },
  {
    icon: "code",
    title: "Performance Engineering",
    body: "Bespoke engineering tailored to your needs. I choose the specific stack—whether Next.js, React, or TypeScript—that guarantees ultimate performance for your project.",
  },
  {
    icon: "automation",
    title: "Revenue Automation",
    body: "Intelligent workflows that work while you sleep. Automated lead capture, AI qualification, and revenue engines that drive growth on autopilot.",
  },
];
---

<section id="infrastructure" class="py-36 container-fluid">
  <div class="mb-12">
    <p class="text-[var(--step--1)] uppercase tracking-[0.25em] text-[rgb(var(--accent))] font-bold mb-3">
      The Infrastructure
    </p>
    <h2 class="font-display font-bold text-[var(--step-3)] leading-[1.1]">
      Engineered for speed, <br />
      built for <span class="text-[rgb(var(--accent))]">revenue</span>.
    </h2>
  </div>
  
  <div class="grid gap-6 [grid-template-columns:repeat(auto-fit,minmax(min(18rem,100%),1fr))]">
    {pillars.map((pillar) => (
      <div class="pillar-card group">
        <!-- Icon -->
        <div class="icon-container">
          {pillar.icon === "design" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122l9.37-9.37C20.938 4.72 22.5 6.275 22.5 8.25c0 1.975-1.558 3.522-3.411 3.522-1.854 0-3.359-1.49-3.359-3.322 0-1.832 1.505-3.322 3.359-3.322 1.854 0 3.359 1.49 3.359 3.322M9.53 16.122L10.5 17m-1.03-1.122a1.5 1.5 0 11-2.121-2.121m2.121 2.121L5.647 16.848a3.75 3.75 0 01-5.061-5.061L3.899 8.274a1.875 1.875 0 012.652 0L9.53 11.25m-4.03 4.872L4.5 18.75m0 0l2.25-1.5M4.5 18.75l-1.5-2.25M8.55 18.321l-.75 2.25m0 0l2.25-.75" />
            </svg>
          )}
          {pillar.icon === "code" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          )}
          {pillar.icon === "automation" && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          )}
        </div>
        
        <!-- Content -->
        <h3 class="font-display font-bold text-xl text-text mb-3 group-hover:text-[rgb(var(--accent))] transition-colors">
          {pillar.title}
        </h3>
        <p class="text-muted leading-relaxed">
          {pillar.body}
        </p>
      </div>
    ))}
  </div>
</section>

<style>
  .pillar-card {
    background: rgb(var(--panel));
    border: 1px solid rgb(var(--border) / 0.1);
    border-radius: var(--radius-lg, 16px);
    padding: var(--space-4);
    transition: all 0.2s ease-out;
  }

  .pillar-card:hover {
    border-color: rgb(var(--accent) / 0.3);
    transform: translateY(-2px);
  }

  .icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-md, 12px);
    background: rgb(var(--accent) / 0.1);
    color: rgb(var(--accent));
    margin-bottom: 1.5rem;
  }

  .pillar-card:hover .icon-container {
    background: rgb(var(--accent) / 0.2);
  }
</style>
